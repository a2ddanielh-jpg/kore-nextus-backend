# ─────────────────────────────────────────────
# Kore Nextus Backend — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Supabase — from Project Settings → API
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Mercado Pago — https://www.mercadopago.com.br/developers/panel
# Access Token: painel → Credenciais → Produção → Access Token
MP_ACCESS_TOKEN=APP_USR-...
# Webhook secret (opcional) — configurado em MP → Webhooks → Chave secreta
MP_WEBHOOK_SECRET=

# Telegram bot notifications
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Groq AI (optional)
GROQ_API_KEY=gsk_...

# Company info
COMPANY_CNPJ=50890780000160

# URLs
PORT=3001
PUBLIC_URL=https://pag.korenextus.com.br
FRONTEND_URL=https://gestion.korenextus.com
